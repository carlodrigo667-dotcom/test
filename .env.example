# Colosseum Ticket Sniper Configuration
# Copy this to .env and fill in your values

# Target date (YYYY-MM-DD format)
TARGET_DATE=2026-04-04

# Number of tickets
ADULT_TICKETS=2
CHILD_TICKETS=2

# Your email for the booking
EMAIL=your@email.com

# Proxy list (comma-separated, format: IP:PORT:USER:PASS)
# Get proxies from: Webshare.io, IPRoyal, Bright Data, etc.
PROXIES=1.2.3.4:8080:username:password,5.6.7.8:8080:username:password

# Telegram notifications (optional)
# Get your chat ID from @userinfobot on Telegram
TELEGRAM_CHAT_ID=

# Read-only Telegram control bot on server 12 / coordinator
TELEGRAM_CONTROL_BOT_TOKEN=
TELEGRAM_CONTROL_CHAT_ID=

# Check interval in milliseconds (default: 30 seconds)
CHECK_INTERVAL=30000

# Chrome path (usually auto-detected)
# CHROME_PATH=/usr/bin/google-chrome-stable
